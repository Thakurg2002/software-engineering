<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Book a Ride - EliteCabs</title>
    <meta name="description" content="Book your premium ride with EliteCabs today.">
    <link rel="stylesheet" href="/css/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
</head>
<body class="bg-dark">
    <header class="navbar">
        <div class="container nav-content">
            <h1 class="logo"><a href="/" class="logo-link">Elite<span>Cabs</span></a></h1>
            <nav>
                <ul class="nav-links">
                    <li><a href="/">Home</a></li>
                    <li><a href="/book" class="btn-primary">Book Now</a></li>
                </ul>
            </nav>
        </div>
    </header>

    <main class="container page-content">
        <div class="booking-card glass-panel">
            <h2 class="card-title">Where to?</h2>
            <form action="/book" method="POST" class="booking-form">
                
                <div class="form-group">
                    <label for="pickup">Pickup Location</label>
                    <input type="text" id="pickup" name="pickup" placeholder="Enter pickup address" required>
                </div>

                <div class="form-group">
                    <label for="dropoff">Drop-off Location</label>
                    <input type="text" id="dropoff" name="dropoff" placeholder="Enter destination" required>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label for="date">Date</label>
                        <input type="date" id="date" name="date" required>
                    </div>
                    <div class="form-group">
                        <label for="time">Time</label>
                        <input type="time" id="time" name="time" required>
                    </div>
                </div>

                <div class="form-group">
                    <label for="vehicle">Vehicle Type</label>
                    <select id="vehicle" name="vehicle" required>
                        <option value="economy">Economy (Max 4)</option>
                        <option value="premium">Premium (Max 4)</option>
                        <option value="suv">SUV (Max 6)</option>
                    </select>
                </div>

                <button type="submit" class="btn-primary btn-block">Confirm Booking</button>
            </form>
        </div>
    </main>

    <footer class="footer">
        <div class="container">
            <p>&copy; 2026 EliteCabs. All rights reserved.</p>
        </div>
    </footer>
</body>
</html>
